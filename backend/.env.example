NODE_ENV=production
PORT=3001

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=pes_db
DB_USER=pes_user
DB_PASS=sua_senha_segura_aqui

# JWT Secrets (gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_ACCESS_SECRET=troque_por_64_bytes_hex_aleatorio
JWT_REFRESH_SECRET=troque_por_outro_64_bytes_hex_aleatorio
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# CSRF
CSRF_SECRET=troque_por_32_bytes_hex_aleatorio

# Frontend URL (para CORS)
FRONTEND_URL=https://paroquiasagradafamilia.com.br

# Cookie
COOKIE_DOMAIN=paroquiasagradafamilia.com.br
COOKIE_SECURE=true

# Pasta persistente para uploads (evita perder imagens em rebuild/deploy)
UPLOADS_DIR=/home/usuario/domains/paroquiasagradafamilia.com.br/public_html/uploads

# Backup automatico no startup (recomendado em producao)
BACKUP_ENABLED=true
BACKUP_DIR=/home/usuario/backups_pes
BACKUP_PATHS=/home/usuario/uploads_pes
BACKUP_KEEP_DAYS=14
BACKUP_MIN_INTERVAL_HOURS=6
